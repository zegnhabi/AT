# ===========================================
# Portainer Stack - Environment Variables
# ===========================================
# Set these directly in Portainer's stack env config

# App
APP_NAME=BusTicketing
APP_ENV=production
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate
APP_DEBUG=false

# Database
DB_DATABASE=bus_ticketing
DB_USERNAME=busapp
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Timezone
TZ=America/Monterrey
